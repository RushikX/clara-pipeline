# ============================================
# CLARA PIPELINE - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ============================================

# Groq API
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# n8n Settings
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme123
GENERIC_TIMEZONE=America/Edmonton

# GitHub (for issue creation)
# Get from: GitHub → Settings → Developer Settings → Personal Access Tokens
# Scopes needed: repo (full control)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=clara-pipeline

# Account being processed
# Change this when running different accounts
ACCOUNT_ID=bens_electric